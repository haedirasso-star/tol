rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in ['admin@totv.com', 'haedirasso@gmail.com']
        || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }
    function isAuth()  { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // ─── app_config — الإعدادات العامة (قراءة للجميع) ────────
    match /app_config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── users/{uid} — بيانات المستخدم ───────────────────────
    // المستخدم يكتب بياناته الأساسية فقط — لا status/role/subscription
    // (التفعيل يتم من الأدمن فقط لمنع منح النفس بريميوم)
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      // الأدمن يعدّل أي شيء. المالك يعدّل بياناته لكن لا يمنح نفسه premium
      // ولا يغيّر status/role.
      allow update: if isAdmin() || (isOwner(uid)
        && !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['status', 'role', 'is_admin'])
        && (!('subscription' in request.resource.data)
            || request.resource.data.subscription.plan != 'premium'));
      allow delete: if isAdmin();
    }

    // ─── orders — طلبات الشراء/الحوالات ──────────────────────
    // المستخدم ينشئ طلبه الخاص ويقرؤه؛ الأدمن يدير الكل
    match /orders/{id} {
      allow read:   if isAdmin() ||
        (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth() &&
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ─── servers — الرصيد (يحوي كلمات مرور) — للأدمن فقط ──────
    match /servers/{id} {
      allow read, write: if isAdmin();
    }

    // ─── admins — قائمة المشرفين — للأدمن فقط ────────────────
    match /admins/{email} {
      allow read, write: if isAdmin();
    }

    // ─── notifications — قراءة فقط للمسجّلين ─────────────────
    match /notifications/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── online_users ─────────────────────────────────────────
    match /online_users/{uid} {
      allow read:  if isAuth();
      allow write: if isOwner(uid);
    }

    // ─── app_logs ─────────────────────────────────────────────
    match /app_logs/{log} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Catch-all — منع كل شيء آخر ──────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
