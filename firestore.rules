rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['admin@totv.com', 'haedirasso@gmail.com'];
    }
    function isAuth()  { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // ─── app_config — الإعدادات العامة (قراءة للجميع) ────────
    match /app_config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── users/{uid} — بيانات المستخدم ───────────────────────
    // المستخدم يكتب بياناته الأساسية + subscription
    // لا يستطيع تغيير status أو role
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) &&
        !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(['status', 'role', 'is_admin']);
      allow delete: if isAdmin();
    }

    // ─── notifications — قراءة فقط للمسجّلين ─────────────────
    match /notifications/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── online_users ─────────────────────────────────────────
    match /online_users/{uid} {
      allow read:  if isAuth();
      allow write: if isOwner(uid);
    }

    // ─── app_logs ─────────────────────────────────────────────
    match /app_logs/{log} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Catch-all — منع كل شيء آخر ──────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
